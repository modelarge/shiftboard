<script>
// ══════════════════════════════════════════════════
// CONSTANTS & STATE
// ══════════════════════════════════════════════════
const DAYS = ['Mon','Tue','Wed','Thu','Fri','Sat','Sun'];
// ROYGBIV: Red, Orange, Yellow, Green, Blue, Indigo, Violet
const COLORS = ['#FF0000','#FF7F00','#FFFF00','#00FF00','#0000FF','#4B0082','#8B00FF'];

let S = {
  weekOffset: 0,
  staff: [],
  templates: [],
  blocks: [],
  weekTemplates: [],
  cfg: { biz:'', mgr:'', defStart:'06:00', defEnd:'23:00', ot:40 },
};

let tagData = {}, editStaffId = null, editTplId = null, cellCtx = null, selectedColor = {};

// ══════════════════════════════════════════════════
// INIT
// ══════════════════════════════════════════════════
function uid(){ return Math.random().toString(36).substr(2,9); }

function init(){
  load();
  if(!S.templates.length) seedTemplates();
  if(!S.weekTemplates) S.weekTemplates = [];
  renderWeek(); renderPanel(); renderCanvas(); renderIntelBar(); renderConflicts(); renderWeekTemplates(); renderBizLabel();
}

function seedTemplates(){
  S.templates = [
    { id:uid(), name:'Store Schedule', color:'#c0392b',
      rows:[{id:uid(),label:'9:00am–5:00pm'},{id:uid(),label:'11:00am–4:00pm'},{id:uid(),label:'3:00pm–7:00pm'},{id:uid(),label:'4:00pm–8:00pm'},{id:uid(),label:'5:00pm–8:00pm'}]},
    { id:uid(), name:'Manager', color:'#2c7bb6',
      rows:[{id:uid(),label:'7:00am–4:00pm'},{id:uid(),label:'3:00pm–10:30pm'}]},
    { id:uid(), name:'Driver Schedule', color:'#27ae60',
      rows:[{id:uid(),label:'10:00am–4:00pm'},{id:uid(),label:'10:00am–2:00pm'},{id:uid(),label:'3:00pm–9:00pm'}]},
  ];
}

function save(){ localStorage.setItem('sb4', JSON.stringify(S)); }
function persist(){ save(); toast('Saved ✓','ok'); }
function load(){
  try{
    const d = localStorage.getItem('sb4');
    if(d) Object.assign(S, JSON.parse(d));
    else { const old = localStorage.getItem('sb3'); if(old) Object.assign(S, JSON.parse(old)); } // migrate
  }catch(e){}
}

// ══════════════════════════════════════════════════
// WEEK NAVIGATION
// ══════════════════════════════════════════════════
function getWeekDates(){
  const now = new Date();
  const mon = new Date(now);
  mon.setDate(now.getDate()-((now.getDay()+6)%7)+S.weekOffset*7);
  return Array.from({length:7},(_,i)=>{ const d=new Date(mon); d.setDate(mon.getDate()+i); return d; });
}
function wk(dir, reset=false){
  saveWeekSnapshot();
  if(reset) S.weekOffset=0; else S.weekOffset+=dir;
  renderWeek(); renderCanvas();
}
function renderWeek(){
  const ds = getWeekDates();
  document.getElementById('wk-label').textContent =
    ds[0].toLocaleDateString('en-US',{month:'short',day:'numeric'}) + ' – ' +
    ds[6].toLocaleDateString('en-US',{month:'short',day:'numeric',year:'numeric'});
}
function saveWeekSnapshot(){
  localStorage.setItem('sb4_week_'+S.weekOffset, JSON.stringify(S.blocks));
}

// Pull prev week's snapshot into current week
function pullLastWeek(){
  const prevData = localStorage.getItem('sb4_week_'+(S.weekOffset-1));
  if(!prevData){ toast('No saved schedule found for last week','er'); return; }
  try{
    const prev = JSON.parse(prevData);
    prev.forEach(pb=>{
      const existing = S.blocks.find(b=>b.id===pb.id);
      if(existing){
        pb.rows.forEach(pr=>{
          const er = existing.rows.find(r=>r.id===pr.id);
          if(er) er.cells = {...pr.cells};
        });
      } else {
        S.blocks.push(JSON.parse(JSON.stringify(pb)));
      }
    });
    renderBlocks(); renderIntelBar();
    toast('Last week copied ✓','ok');
  }catch(e){ toast('Could not copy last week','er'); }
}

// Push current week's schedule forward into next week
function pushNextWeek(){
  localStorage.setItem('sb4_week_'+(S.weekOffset+1), JSON.stringify(S.blocks));
  toast('Pushed to next week ✓','ok');
}

// ══════════════════════════════════════════════════
// PANEL
// ══════════════════════════════════════════════════
function renderPanel(){
  document.getElementById('tpl-list').innerHTML = S.templates.map(t=>`
    <div class="tpl-chip" draggable="true" data-tpl="${t.id}" ondragstart="tplDragStart(event,'${t.id}')">
      <div class="tpl-color" style="background:${t.color}"></div>
      <div class="tpl-info">
        <div class="tpl-name">${t.name}</div>
        <div class="tpl-sub">${t.rows.length} row${t.rows.length!==1?'s':''}</div>
      </div>
      <div class="tpl-actions">
        <button class="tpl-act" onclick="openEditTpl('${t.id}')" title="Edit">✏</button>
        <button class="tpl-act del" onclick="deleteTpl('${t.id}')" title="Delete">✕</button>
      </div>
    </div>`).join('');

  const slist = document.getElementById('staff-list-panel');
  if(!S.staff.length){
    slist.innerHTML='<div style="font-size:.73rem;color:var(--text3);padding:4px 12px">No staff yet.</div>';
  } else {
    slist.innerHTML = S.staff.map(e=>`
      <div class="staff-item" draggable="true" data-emp="${e.id}" ondragstart="empDragStart(event,'${e.id}')">
        <span class="staff-dot" style="background:${e.color}"></span>
        <span class="staff-item-name">${e.fname} ${e.lname}</span>
        <button style="border:none;background:none;cursor:pointer;color:var(--text3);font-size:.7rem;padding:2px 4px;border-radius:3px;transition:.1s"
          onmouseenter="this.style.color='var(--text)'" onmouseleave="this.style.color='var(--text3)'"
          onclick="openEditStaff('${e.id}')">✏</button>
        <button style="border:none;background:none;cursor:pointer;color:var(--text3);font-size:.7rem;padding:2px 4px;border-radius:3px;transition:.1s"
          onmouseenter="this.style.color='#ff8080'" onmouseleave="this.style.color='var(--text3)'"
          onclick="deleteStaff('${e.id}')">✕</button>
      </div>`).join('');
  }
}

// ══════════════════════════════════════════════════
// CANVAS
// ══════════════════════════════════════════════════
function getCanvasColW(){
  const cw = document.getElementById('canvas-wrap').clientWidth;
  return Math.max(Math.floor((cw-86)/7), 80);
}
function renderCanvas(){
  const canvas = document.getElementById('canvas');
  const wrap = document.getElementById('canvas-wrap');
  const totalW = Math.max(wrap.clientWidth, 86+getCanvasColW()*7);
  canvas.style.width = totalW+'px';
  renderBlocks();
  canvas.ondragover = e => e.preventDefault();
  canvas.ondrop = e => {
    e.preventDefault();
    const tplId = e.dataTransfer.getData('tplId');
    if(tplId){
      const wr = wrap.getBoundingClientRect();
      dropTemplate(tplId, e.clientX-wr.left+wrap.scrollLeft, e.clientY-wr.top+wrap.scrollTop);
    }
  };
}
function renderBlocks(){
  const layer = document.getElementById('blocks-layer');
  layer.innerHTML = '';
  S.blocks.forEach(b=>layer.appendChild(buildBlockEl(b)));
}
function buildBlockEl(block){
  const el = document.createElement('div');
  el.className = 'sched-block';
  el.id = 'blk-'+block.id;
  el.style.left = block.x+'px';
  el.style.top = block.y+'px';
  el.style.width = (block.w||760)+'px';

  // Header
  const hdr = document.createElement('div');
  hdr.className = 'block-hdr';
  hdr.innerHTML = `
    <div class="block-hdr-color" style="background:${block.color}"></div>
    <div class="block-hdr-title" contenteditable="true"
      onblur="block_rename('${block.id}',this.innerText)"
      style="color:${block.color}">${block.label}</div>
    <div class="block-hdr-actions">
      <input type="color" value="${block.color}" title="Change color"
        onchange="block_recolor('${block.id}',this.value)"
        style="width:22px;height:22px;border-radius:4px;border:1px solid #ddd;padding:1px;cursor:pointer">
      <button class="bha" onclick="addBlockRow('${block.id}')" title="Add row">+row</button>
      <button class="bha del" onclick="removeBlock('${block.id}')" title="Delete block">✕</button>
    </div>`;
  hdr.addEventListener('mousedown', e=>{
    if(e.target.closest('[contenteditable]')||e.target.closest('input')||e.target.closest('button')) return;
    startBlockDrag(e, block.id);
  });
  el.appendChild(hdr);

  // Table
  const tbl = document.createElement('table');
  tbl.className = 'block-table';
  const thead = document.createElement('thead');
  const thr = document.createElement('tr');
  thr.innerHTML = `<th class="time-th"></th>`+DAYS.map(d=>`<th>${d}</th>`).join('');
  thead.appendChild(thr); tbl.appendChild(thead);

  const tbody = document.createElement('tbody');
  block.rows.forEach(row=>{
    const tr = document.createElement('tr');
    const timeTd = document.createElement('td');
    timeTd.className = 'time-td';
    timeTd.innerHTML = `<div class="time-slot-lbl" onclick="openTimeEdit('${block.id}','${row.id}')" title="Click to edit">${row.label}</div>
      ${block.rows.length>1?`<div style="font-size:.55rem;color:#ccc;cursor:pointer;margin-top:3px" onclick="removeBlockRow('${block.id}','${row.id}')">✕ row</div>`:''}`;
    tr.appendChild(timeTd);

    for(let di=0;di<7;di++){
      const td = document.createElement('td');
      td.dataset.bid = block.id; td.dataset.rid = row.id; td.dataset.day = di;
      const shifts = ((row.cells||{})[di]||[]);
      const visible = S.showHidden ? shifts : shifts.filter(s=>!s.hidden);
      visible.forEach(sh=>{
        const emp = S.staff.find(e=>e.id===sh.empId);
        const name = emp ? `${emp.fname} ${emp.lname[0]}.` : (sh.empName||'?');
        const color = emp ? emp.color : '#888';
        const chip = document.createElement('span');
        chip.className = 'ncell-chip';
        chip.dataset.shiftId = sh.id;
        if(sh.hidden) chip.dataset.hidden = true;
        chip.style.background = hexA(color,.13);
        chip.style.borderColor = hexA(color,.35);
        chip.style.color = color;
        chip.title = [name, sh.start&&sh.end?`${sh.start}–${sh.end}`:'', sh.note?`"${sh.note}"`:'', sh.hidden?'(hidden)':''].filter(Boolean).join('\n');
        chip.innerHTML = `<span class="nc-dot" style="background:${color}"></span>${name}${sh.note?`<span style="font-size:.62rem;opacity:.6;margin-left:3px">${sh.note}</span>`:''}
          <button class="nc-x" onclick="removeShift('${block.id}','${row.id}',${di},'${sh.id}',event)">✕</button>`;
        chip.addEventListener('click', ev=>{ if(ev.target.classList.contains('nc-x')) return; openCellModal(block.id,row.id,di,sh.id,block.color); });
        chip.draggable = true;
        chip.addEventListener('dragstart', ev=>{ window._shiftDrag={bid:block.id,rid:row.id,di,shiftId:sh.id}; ev.dataTransfer.effectAllowed='move'; ev.stopPropagation(); });
        td.appendChild(chip);
      });
      const addBtn = document.createElement('button');
      addBtn.className = 'add-cell-btn'; addBtn.textContent = '+';
      addBtn.addEventListener('click', ()=>openCellModal(block.id,row.id,di,null,block.color));
      td.appendChild(addBtn);
      td.addEventListener('dragover', ev=>{ ev.preventDefault(); td.style.background='rgba(74,144,226,.08)'; });
      td.addEventListener('dragleave', ()=>{ td.style.background=''; });
      td.addEventListener('drop', ev=>{
        ev.preventDefault(); td.style.background='';
        const empId = ev.dataTransfer.getData('empId');
        const shDrag = window._shiftDrag;
        if(empId){ dropEmpOnCell(block.id,row.id,di,empId); }
        else if(shDrag){ moveShift(shDrag,block.id,row.id,di); window._shiftDrag=null; }
        ev.stopPropagation();
      });
      tr.appendChild(td);
    }
    tbody.appendChild(tr);
  });
  tbl.appendChild(tbody);
  el.appendChild(tbl);
  const rh = document.createElement('div');
  rh.className = 'resize-handle';
  rh.addEventListener('mousedown', e=>startResize(e,block.id));
  el.appendChild(rh);
  return el;
}

// ── BLOCK DRAG ──
let _blockDrag = null;
function startBlockDrag(e, blockId){
  const el = document.getElementById('blk-'+blockId);
  const rect = el.getBoundingClientRect();
  _blockDrag = {blockId, offX:e.clientX-rect.left, offY:e.clientY-rect.top};
  el.classList.add('dragging-block');
  document.addEventListener('mousemove', onBlockMove);
  document.addEventListener('mouseup', onBlockUp);
  e.preventDefault();
}
function onBlockMove(e){
  if(!_blockDrag) return;
  const wrap = document.getElementById('canvas-wrap');
  const wr = wrap.getBoundingClientRect();
  const x = e.clientX-wr.left+wrap.scrollLeft-_blockDrag.offX;
  const y = e.clientY-wr.top+wrap.scrollTop-_blockDrag.offY;
  const el = document.getElementById('blk-'+_blockDrag.blockId);
  el.style.left=Math.max(0,x)+'px'; el.style.top=Math.max(0,y)+'px';
}
function onBlockUp(){
  if(!_blockDrag) return;
  const el = document.getElementById('blk-'+_blockDrag.blockId);
  el.classList.remove('dragging-block');
  const b = S.blocks.find(b=>b.id===_blockDrag.blockId);
  if(b){ b.x=parseInt(el.style.left)||0; b.y=parseInt(el.style.top)||0; }
