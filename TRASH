<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ShiftBoard</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root {
  --bg: #1c1c1e;
  --panel: #242426;
  --panel2: #2c2c2f;
  --border: #3a3a3e;
  --border2: #4a4a50;
  --text: #f0f0f0;
  --text2: #a0a0a8;
  --text3: #606068;
  --canvas-text: #1a1a18;
  --accent: #e8450a;
  --panel-w: 240px;
  --top-h: 52px;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{font-size:13px}
body{background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;height:100vh;overflow:hidden;display:flex;flex-direction:column}

/* ── TOPBAR ── */
#topbar{
  height:var(--top-h);flex-shrink:0;
  background:var(--panel);border-bottom:1px solid var(--border);
  display:flex;align-items:center;gap:10px;padding:0 16px;z-index:200;
}
.logo{font-family:'Bebas Neue',sans-serif;font-size:1.6rem;letter-spacing:2px;color:#fff;line-height:1}
.logo span{color:var(--accent)}
.divider{width:1px;height:28px;background:var(--border);margin:0 4px}
.week-pill{
  display:flex;align-items:center;gap:6px;
  background:var(--panel2);border:1px solid var(--border);border-radius:6px;padding:4px 8px;
}
.week-text{font-family:'JetBrains Mono',monospace;font-size:0.78rem;color:var(--text2);min-width:160px;text-align:center}
.ico-btn{
  width:28px;height:28px;border-radius:5px;border:none;
  background:transparent;color:var(--text2);cursor:pointer;
  display:flex;align-items:center;justify-content:center;font-size:0.9rem;transition:all .12s;
}
.ico-btn:hover{background:var(--panel2);color:var(--text)}
.ml{margin-left:auto}
.tb-btn{
  padding:6px 14px;border-radius:6px;border:none;cursor:pointer;
  font-family:'DM Sans',sans-serif;font-weight:600;font-size:0.78rem;
  transition:all .12s;display:flex;align-items:center;gap:5px;white-space:nowrap;
}
.tb-btn.ghost{background:var(--panel2);color:var(--text2);border:1px solid var(--border)}
.tb-btn.ghost:hover{color:var(--text);border-color:var(--border2)}
.tb-btn.hot{background:var(--accent);color:#fff}
.tb-btn.hot:hover{background:#ff5520}

/* ── LAYOUT ── */
#body{display:flex;flex:1;overflow:hidden}

/* ── LEFT PANEL ── */
#panel{
  width:var(--panel-w);flex-shrink:0;
  background:var(--panel);border-right:1px solid var(--border);
  display:flex;flex-direction:column;overflow:hidden;
}
.panel-section{border-bottom:1px solid var(--border);padding:12px}
.panel-head{font-family:'Bebas Neue',sans-serif;letter-spacing:1.5px;font-size:0.85rem;color:var(--text3);margin-bottom:10px;}
.tpl-chip{
  display:flex;align-items:center;gap:8px;padding:9px 10px;border-radius:7px;
  background:var(--panel2);border:1px solid var(--border);margin-bottom:6px;
  cursor:grab;user-select:none;transition:all .12s;position:relative;
}
.tpl-chip:hover{border-color:var(--border2);transform:translateX(3px);box-shadow:0 2px 10px rgba(0,0,0,.3)}
.tpl-chip:active{cursor:grabbing}
.tpl-color{width:4px;align-self:stretch;border-radius:2px;flex-shrink:0}
.tpl-info{flex:1;min-width:0}
.tpl-name{font-weight:600;font-size:0.82rem;color:var(--text)}
.tpl-sub{font-size:0.68rem;color:var(--text3);margin-top:1px}
.tpl-actions{display:flex;gap:3px;opacity:0;transition:.12s}
.tpl-chip:hover .tpl-actions{opacity:1}
.tpl-act{
  width:20px;height:20px;border-radius:4px;border:none;
  background:var(--border);color:var(--text2);cursor:pointer;
  display:flex;align-items:center;justify-content:center;font-size:0.62rem;transition:.1s;
}
.tpl-act:hover{background:var(--border2);color:var(--text)}
.tpl-act.del:hover{background:#5a1010;color:#ff8080}
.new-tpl-btn{
  width:100%;padding:7px;border-radius:6px;background:none;border:1px dashed var(--border2);
  color:var(--text3);cursor:pointer;font-size:0.75rem;font-weight:600;transition:all .12s;margin-top:2px;
}
.new-tpl-btn:hover{border-color:var(--accent);color:var(--accent)}
#staff-list-panel{flex:1;overflow-y:auto;padding:12px}
.staff-item{
  display:flex;align-items:center;gap:7px;padding:6px 8px;border-radius:6px;
  cursor:grab;user-select:none;margin-bottom:4px;transition:all .12s;
}
.staff-item:hover{background:var(--panel2)}
.staff-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0}
.staff-item-name{font-size:0.8rem;font-weight:500;flex:1}
.add-staff-btn{
  width:100%;padding:7px;border-radius:6px;background:none;border:1px dashed var(--border2);
  color:var(--text3);cursor:pointer;font-size:0.75rem;font-weight:600;transition:all .12s;margin-top:4px;flex-shrink:0;
}
.add-staff-btn:hover{border-color:var(--accent);color:var(--accent)}

/* ── CANVAS ── */
#canvas-wrap{flex:1;overflow:auto;position:relative}
#canvas{position:relative;background:var(--bg);min-width:1100px;min-height:700px;}
#blocks-layer{position:absolute;top:0;left:0;width:100%;height:100%;pointer-events:none}
#blocks-layer .sched-block{pointer-events:all}
.sched-block{
  position:absolute;z-index:10;background:#fff;border:2px solid #d0ccc4;
  border-radius:6px;box-shadow:0 4px 20px rgba(0,0,0,.12);
  min-width:180px;min-height:60px;overflow:visible;transition:box-shadow .15s;
}
.sched-block:hover{box-shadow:0 6px 28px rgba(0,0,0,.18)}
.sched-block.dragging-block{opacity:.85;box-shadow:0 12px 40px rgba(0,0,0,.3);z-index:100}
.block-hdr{
  display:flex;align-items:center;border-bottom:2px solid #d0ccc4;
  cursor:move;user-select:none;border-radius:4px 4px 0 0;overflow:hidden;
}
.block-hdr-color{width:6px;align-self:stretch;flex-shrink:0}
.block-hdr-title{
  flex:1;padding:7px 10px;font-family:'Bebas Neue',sans-serif;
  letter-spacing:1px;font-size:1rem;color:var(--canvas-text);outline:none;white-space:nowrap;overflow:hidden;
}
.block-hdr-title:focus{background:rgba(0,0,0,.03)}
.block-hdr-actions{display:flex;align-items:center;gap:2px;padding:4px 6px;opacity:0;transition:.12s;}
.sched-block:hover .block-hdr-actions{opacity:1}
.bha{
  width:22px;height:22px;border-radius:4px;border:none;background:rgba(0,0,0,.06);
  cursor:pointer;color:#666;display:flex;align-items:center;justify-content:center;font-size:0.65rem;transition:.1s;
}
.bha:hover{background:rgba(0,0,0,.12);color:#333}
.bha.del:hover{background:#fde;color:#c0392b}
.block-table{width:100%;border-collapse:collapse;table-layout:fixed;}
.block-table th{
  padding:5px 6px;text-align:center;border-right:1px solid #e0dcd4;border-bottom:1px solid #d0ccc4;
  font-family:'JetBrains Mono',monospace;font-size:0.62rem;color:#999;background:#faf9f6;font-weight:500;
}
.block-table th.time-th{text-align:left;font-size:0.65rem;color:#666;width:80px;background:#f5f3ee;font-weight:600;}
.block-table td{
  padding:4px 5px;border-right:1px solid #e8e4dc;border-bottom:1px solid #e8e4dc;
  vertical-align:top;min-height:44px;height:44px;position:relative;
}
.block-table td.time-td{background:#faf9f6;border-right:1.5px solid #d0ccc4;vertical-align:middle;text-align:center;}
.time-slot-lbl{
  font-family:'JetBrains Mono',monospace;font-size:0.62rem;color:#888;
  line-height:1.4;cursor:pointer;padding:2px;border-radius:3px;transition:.1s;
}
.time-slot-lbl:hover{background:rgba(0,0,0,.06);color:#444}
.block-table td:last-child{border-right:none}
.block-table tr:last-child td{border-bottom:none}
.ncell-chip{
  display:inline-flex;align-items:center;gap:4px;padding:3px 7px 3px 5px;border-radius:4px;
  font-family:'DM Sans',sans-serif;font-weight:600;font-size:0.78rem;
  cursor:pointer;margin:1px;white-space:nowrap;border:1.5px solid transparent;transition:all .1s;position:relative;
}
.ncell-chip:hover{filter:brightness(.92)}
.ncell-chip .nc-dot{width:6px;height:6px;border-radius:50%;flex-shrink:0}
.ncell-chip .nc-x{
  width:12px;height:12px;border-radius:50%;border:none;background:rgba(0,0,0,.15);
  cursor:pointer;color:rgba(0,0,0,.5);display:none;align-items:center;justify-content:center;
  font-size:0.5rem;margin-left:2px;flex-shrink:0;
}
.ncell-chip:hover .nc-x{display:flex}
.ncell-chip[data-hidden]{opacity:.35}
.add-cell-btn{
  display:inline-flex;align-items:center;gap:2px;padding:2px 6px;border-radius:3px;
  border:1px dashed #ccc;background:none;color:#bbb;cursor:pointer;font-size:0.68rem;transition:all .1s;margin:1px;
}
.add-cell-btn:hover{border-color:#4a90e2;color:#4a90e2;background:rgba(74,144,226,.05)}
.resize-handle{position:absolute;bottom:0;right:0;width:14px;height:14px;cursor:se-resize;opacity:0;transition:.12s;}
.resize-handle::after{
  content:'';position:absolute;bottom:3px;right:3px;width:8px;height:8px;
  border-right:2px solid #aaa;border-bottom:2px solid #aaa;border-radius:0 0 2px 0;
}
.sched-block:hover .resize-handle{opacity:1}

/* ── MODALS ── */
.moverlay{
  position:fixed;inset:0;z-index:500;background:rgba(0,0,0,.65);backdrop-filter:blur(3px);
  display:flex;align-items:center;justify-content:center;opacity:0;pointer-events:none;transition:opacity .18s;
}
.moverlay.open{opacity:1;pointer-events:all}
.modal{
  background:var(--panel);border:1px solid var(--border2);border-radius:10px;padding:22px;
  width:460px;max-width:95vw;max-height:90vh;overflow-y:auto;
  box-shadow:0 20px 60px rgba(0,0,0,.6);transform:translateY(8px);transition:transform .18s;
}
.moverlay.open .modal{transform:translateY(0)}
.modal-h{font-family:'Bebas Neue',sans-serif;letter-spacing:1.5px;font-size:1.2rem;margin-bottom:16px;display:flex;align-items:center;gap:10px;color:var(--text);}
.modal-accent{width:5px;height:22px;border-radius:3px}
label.fl{display:block;font-size:0.72rem;font-weight:600;color:var(--text2);margin-bottom:4px;margin-top:10px;text-transform:uppercase;letter-spacing:.5px}
label.fl:first-child{margin-top:0}
input[type=text],input[type=time],input[type=email],input[type=number],select,textarea{
  width:100%;padding:8px 10px;background:var(--panel2);border:1px solid var(--border2);
  border-radius:6px;color:var(--text);font-family:'DM Sans',sans-serif;font-size:.82rem;outline:none;transition:border-color .12s;
}
input:focus,select:focus,textarea:focus{border-color:#4a90e2}
textarea{resize:vertical;min-height:60px}
select option{background:var(--panel2)}
.frow{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.mfooter{display:flex;gap:7px;justify-content:flex-end;margin-top:18px;padding-top:14px;border-top:1px solid var(--border)}
.m-cancel{padding:7px 16px;border-radius:6px;background:var(--panel2);border:1px solid var(--border2);color:var(--text2);cursor:pointer;font-family:'DM Sans',sans-serif;font-weight:600;font-size:.8rem;transition:all .12s}
.m-cancel:hover{color:var(--text);border-color:var(--border)}
.m-save{padding:7px 18px;border-radius:6px;background:var(--accent);border:none;color:#fff;cursor:pointer;font-family:'DM Sans',sans-serif;font-weight:700;font-size:.8rem;transition:all .12s}
.m-save:hover{background:#ff5520}
.sdiv{font-size:.65rem;font-weight:700;color:var(--text3);text-transform:uppercase;letter-spacing:1.5px;margin-top:14px;margin-bottom:5px;padding-top:12px;border-top:1px solid var(--border)}
.priv-note{background:rgba(255,170,50,.06);border:1px solid rgba(255,170,50,.2);border-radius:6px;padding:8px 10px;font-size:.72rem;color:var(--text2);margin-bottom:8px}
.color-row{display:flex;gap:6px;flex-wrap:wrap;margin-top:4px}
.csw{width:24px;height:24px;border-radius:50%;cursor:pointer;border:2px solid transparent;transition:all .12s}
.csw.on{border-color:#fff;transform:scale(1.15)}
.tag-wrap{display:flex;flex-wrap:wrap;gap:5px;padding:7px;background:var(--panel2);border:1px solid var(--border2);border-radius:6px;min-height:36px;cursor:text;margin-top:4px}
.tag{padding:2px 8px;border-radius:100px;background:rgba(74,144,226,.15);color:#4a90e2;font-size:.7rem;font-weight:600;display:flex;align-items:center;gap:4px}
.tag-x{cursor:pointer;opacity:.6}.tag-x:hover{opacity:1}
.tag-input{border:none;background:none;color:var(--text);font-family:'DM Sans',sans-serif;font-size:.8rem;outline:none;flex:1;min-width:70px}
.avrow{display:flex;gap:4px;margin-top:4px}
.avbox{flex:1;padding:6px 2px;border-radius:5px;background:var(--panel2);border:1px solid var(--border2);text-align:center;cursor:pointer;transition:all .12s}
.avbox .avd{font-family:'JetBrains Mono',monospace;font-size:.62rem;color:var(--text3);text-transform:uppercase}
.avbox input{display:block;margin:4px auto 0;accent-color:#27ae60;cursor:pointer}
.avbox.on{border-color:#27ae60;background:rgba(39,174,96,.08)}
.avbox.on .avd{color:#27ae60}
.form-check{display:flex;align-items:center;gap:7px;padding:7px 10px;border-radius:6px;border:1px solid var(--border2);background:var(--panel2);margin-top:8px;cursor:pointer}
.form-check input{accent-color:var(--accent);width:14px;height:14px;cursor:pointer}
.form-check span{font-size:.8rem;font-weight:500}

/* ── SMART TOOLS BAR ── */
#phase1-bar{
  display:flex;align-items:center;gap:6px;padding:6px 14px;
  background:var(--panel);border-bottom:1px solid var(--border);flex-wrap:wrap;
}
.p1-btn{
  padding:5px 11px;border-radius:5px;border:1px solid var(--border2);
  background:var(--panel2);color:var(--text2);cursor:pointer;
  font-family:'DM Sans',sans-serif;font-size:.75rem;font-weight:600;
  transition:all .12s;display:flex;align-items:center;gap:5px;
}
.p1-btn:hover{color:var(--text);border-color:var(--border);background:var(--panel)}
.p1-sep{width:1px;height:20px;background:var(--border);margin:0 2px}
.p1-label{font-size:.68rem;color:var(--text3);font-weight:600;letter-spacing:.5px;text-transform:uppercase}
.wtpl-chip{
  display:inline-flex;align-items:center;gap:5px;padding:4px 9px;border-radius:5px;
  background:var(--panel2);border:1px solid var(--border2);font-size:.73rem;font-weight:600;cursor:pointer;transition:all .12s;
}
.wtpl-chip:hover{border-color:var(--accent);color:var(--accent)}
.wtpl-chip .wtpl-x{opacity:.5;margin-left:3px;font-size:.65rem}
.wtpl-chip .wtpl-x:hover{opacity:1}

/* ── CONFLICT BANNER ── */
#conflict-banner{
  position:sticky;top:0;z-index:80;background:rgba(232,69,10,.12);border-bottom:1px solid rgba(232,69,10,.3);
  padding:0;max-height:0;overflow:hidden;transition:max-height .2s,padding .2s;
}
#conflict-banner.has-conflicts{max-height:200px;padding:6px 14px}
.cf-row{display:flex;align-items:center;gap:7px;font-size:.75rem;color:#ff8060;padding:2px 0}
.cf-row::before{content:'⚠';flex-shrink:0}

/* ── INTELLIGENCE BAR ── */
#intel-bar{
  flex-shrink:0;min-height:58px;height:58px;
  background:var(--panel);border-top:2px solid var(--accent);
  display:flex;align-items:stretch;overflow:hidden;z-index:100;position:relative;
}
#intel-bar-resize{position:absolute;top:0;left:0;right:0;height:5px;cursor:ns-resize;background:transparent;z-index:10;}
#intel-bar-resize:hover{background:rgba(255,255,255,.07)}
.ib-label{
  font-family:'Bebas Neue',sans-serif;letter-spacing:1px;font-size:.75rem;color:var(--text3);
  writing-mode:horizontal-tb;padding:0 12px;display:flex;align-items:center;
  border-right:1px solid var(--border);flex-shrink:0;
}
#intel-scroll{
  display:flex;align-items:center;gap:6px;padding:6px 12px;
  overflow-x:auto;overflow-y:hidden;flex:1;
}
#intel-scroll::-webkit-scrollbar{height:3px}
#intel-scroll::-webkit-scrollbar-thumb{background:var(--border2);border-radius:2px}
.intel-pill{
  display:flex;flex-direction:column;gap:2px;padding:5px 10px;border-radius:7px;
  background:var(--panel2);border:1px solid var(--border);
  min-width:115px;max-width:160px;flex-shrink:0;transition:border-color .12s;
}
.intel-pill:hover{border-color:var(--border2)}
.intel-pill.ot{border-color:rgba(230,126,34,.5)}
.intel-pill.warn{border-color:rgba(232,69,10,.6);background:rgba(232,69,10,.07)}
.ip-top{display:flex;align-items:center;gap:5px}
.ip-dot{width:7px;height:7px;border-radius:50%;flex-shrink:0}
.ip-name{font-weight:600;font-size:.77rem;color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;flex:1}
.ip-hrs{font-family:'JetBrains Mono',monospace;color:var(--text2);font-size:.67rem;flex-shrink:0}
.ip-hrs.ot-hrs{color:#e67e22}
.ip-issues{font-size:.62rem;color:#ff8060;font-weight:600;line-height:1.4;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}

/* ── TOASTS ── */
#toasts{position:fixed;bottom:70px;right:14px;z-index:1000;display:flex;flex-direction:column;gap:5px}
.toast{padding:8px 14px;border-radius:6px;background:var(--panel2);border:1px solid var(--border2);color:var(--text);font-size:.78rem;font-weight:600;box-shadow:0 4px 20px rgba(0,0,0,.4);animation:tin .18s ease;display:flex;align-items:center;gap:7px}
.toast.ok{border-left:3px solid #27ae60}
.toast.er{border-left:3px solid var(--accent)}
@keyframes tin{from{transform:translateX(12px);opacity:0}to{transform:translateX(0);opacity:1}}

/* ── PRINT ── */
@media print{
  @page{size:landscape;margin:8mm}
  *{-webkit-print-color-adjust:exact!important;print-color-adjust:exact!important}
  body{background:#fff!important;overflow:visible!important;height:auto!important;display:block!important}
  #topbar,#panel,#intel-bar,#phase1-bar,#conflict-banner,.block-hdr-actions,.add-cell-btn,.nc-x,.resize-handle,.moverlay{display:none!important}
  #body{display:block!important;overflow:visible!important;height:auto!important}
  #canvas-wrap{overflow:visible!important;height:auto!important;margin:0!important;padding:0!important}
  #blocks-layer{position:relative!important;height:auto!important}
  #canvas{background:#fff!important;min-height:auto!important;width:100%!important;height:auto!important;overflow:visible!important}
  .sched-block{box-shadow:none!important;border:1.5px solid #aaa!important;break-inside:avoid;page-break-inside:avoid;position:relative!important;left:auto!important;top:auto!important;width:100%!important;margin-bottom:10pt!important;display:block!important;}
  .block-hdr{background:#efefef!important;border-radius:0!important}
  .block-table{width:100%!important;table-layout:fixed!important;border-collapse:collapse!important}
  .block-table th,.block-table td{font-size:7.5pt!important;padding:3pt 3pt!important;word-break:break-word!important;border:0.5pt solid #ccc!important}
  .block-table th{background:#f5f5f5!important}
  .block-table td.time-td{width:72pt!important;min-width:72pt!important}
  .ncell-chip{font-size:7pt!important;padding:1pt 3pt!important;display:inline-block!important;margin:1pt!important}
  [data-hidden]{display:none!important}
}
</style>
</head>
<body>

<!-- TOPBAR -->
<div id="topbar">
  <div class="logo">Shift<span>Board</span></div>
  <div class="divider"></div>
  <div class="week-pill">
    <button class="ico-btn" onclick="wk(-1)" title="Previous week">‹</button>
    <span class="week-text" id="wk-label">—</span>
    <button class="ico-btn" onclick="wk(1)" title="Next week">›</button>
    <button class="ico-btn" onclick="wk(0,true)" style="font-size:.65rem;width:34px" title="Jump to today">NOW</button>
  </div>
  <div class="divider"></div>
  <span style="font-size:.75rem;color:var(--text3)" id="biz-label"></span>
  <div class="ml" style="display:flex;gap:6px;align-items:center">
    <button class="tb-btn ghost" onclick="pullLastWeek()" title="Copy previous week's shifts into this week">↑ Pull Prev</button>
    <button class="tb-btn ghost" onclick="pushNextWeek()" title="Copy this week's shifts into next week">↓ Push Next</button>
    <div class="divider"></div>
    <button class="tb-btn ghost" onclick="exportCSV()">↓ CSV</button>
    <button class="tb-btn ghost" onclick="exportPDF()">⎙ Print / PDF</button>
    <button class="tb-btn ghost" onclick="openSettings()">⚙</button>
    <button class="tb-btn hot" onclick="persist()">Save</button>
  </div>
</div>

<!-- BODY -->
<div id="body">

  <!-- LEFT PANEL -->
  <div id="panel">
    <div class="panel-section">
      <div class="panel-head">Block Templates</div>
      <div id="tpl-list"></div>
      <button class="new-tpl-btn" onclick="openNewTplModal()">+ New Template</button>
    </div>
