    let rowsHtml='';
    b.rows.forEach(row=>{
      let cells='<td style="width:80px;font-family:monospace;font-size:7pt;color:#555;background:#faf9f6;border:0.5pt solid #ccc;padding:3pt;text-align:center;vertical-align:middle">'+row.label+'</td>';
      for(let di=0;di<7;di++){
        const shifts=((row.cells||{})[di]||[]).filter(s=>!s.hidden);
        let chipHtml=shifts.map(sh=>{
          const emp=S.staff.find(e=>e.id===sh.empId);
          const name=emp?`${emp.fname} ${emp.lname[0]}.`:(sh.empName||'?');
          const color=emp?emp.color:'#888';
          const r=parseInt(color.slice(1,3),16),g=parseInt(color.slice(3,5),16),bv=parseInt(color.slice(5,7),16);
          return`<span style="display:inline-block;margin:1pt;padding:1pt 4pt;border-radius:3pt;font-size:7pt;font-weight:600;background:rgba(${r},${g},${bv},0.13);border:1pt solid rgba(${r},${g},${bv},0.4);color:${color}">${name}</span>`;
        }).join('');
        cells+=`<td style="border:0.5pt solid #ccc;padding:3pt;vertical-align:top;font-size:7pt">${chipHtml||''}</td>`;
      }
      rowsHtml+=`<tr>${cells}</tr>`;
    });
    blocksHtml+=`
      <div style="margin-bottom:12pt;break-inside:avoid;page-break-inside:avoid">
        <div style="background:#efefef;padding:5pt 8pt;border:1pt solid #aaa;border-bottom:none;display:flex;align-items:center;gap:6pt">
          <div style="width:5pt;height:16pt;background:${b.color};border-radius:2pt;flex-shrink:0"></div>
          <strong style="font-size:10pt;letter-spacing:1pt;font-family:sans-serif">${b.label}</strong>
        </div>
        <table style="width:100%;border-collapse:collapse;table-layout:fixed">
          <thead><tr>
            <th style="width:80px;border:0.5pt solid #ccc;padding:3pt;background:#f5f5f5;font-size:7pt;font-family:monospace"></th>
            ${dates.map((d,i)=>`<th style="border:0.5pt solid #ccc;padding:3pt;background:#f5f5f5;font-size:7.5pt;text-align:center;font-family:sans-serif">${DAYS[i]}<br><span style="font-weight:400;color:#888">${d.getMonth()+1}/${d.getDate()}</span></th>`).join('')}
          </tr></thead>
          <tbody>${rowsHtml}</tbody>
        </table>
      </div>`;
  });

  const html=`<!DOCTYPE html><html><head><meta charset="UTF-8">
  <style>
    @page{size:landscape;margin:10mm}
    *{-webkit-print-color-adjust:exact;print-color-adjust:exact;box-sizing:border-box}
    body{font-family:sans-serif;margin:0;padding:0;background:#fff;color:#222}
    h1{font-size:14pt;margin:0 0 2pt 0}
    .sub{font-size:8pt;color:#888;margin-bottom:10pt}
  </style>
  </head><body>
  <h1>${bizName}${S.cfg.mgr?' — '+S.cfg.mgr:''}</h1>
  <div class="sub">Week of ${weekLabel}</div>
  ${blocksHtml}
  <script>window.onload=()=>{window.print();window.onafterprint=()=>window.close();}<\/script>
  </body></html>`;

  const w=window.open('','_blank','width=1100,height=700');
  if(w){ w.document.write(html); w.document.close(); }
  else toast('Allow popups to generate PDF','er');
}

function exportCSV(){  const dates=getWeekDates();
  const rows=[['Block','Time Slot','Day','Date','Employee','Start','End','Note','Hidden']];
  S.blocks.forEach(b=>b.rows.forEach(r=>dates.forEach((d,di)=>{
    ((r.cells||{})[di]||[]).forEach(s=>{
      const emp=S.staff.find(e=>e.id===s.empId);
      rows.push([b.label,r.label,DAYS[di],`${d.getMonth()+1}/${d.getDate()}`,
        emp?`${emp.fname} ${emp.lname}`:s.empName,s.start,s.end,s.note||'',s.hidden?'Yes':'No']);
    });
  })));
  const csv=rows.map(r=>r.map(v=>`"${String(v).replace(/"/g,'""')}"`).join(',')).join('\n');
  const a=document.createElement('a');
  a.href=URL.createObjectURL(new Blob([csv],{type:'text/csv'}));
  a.download=`schedule-${new Date().toISOString().slice(0,10)}.csv`;
  a.click(); toast('CSV exported ✓','ok');
}
function exportBackup(){
  const a=document.createElement('a');
  a.href=URL.createObjectURL(new Blob([JSON.stringify(S,null,2)],{type:'application/json'}));
  a.download='shiftboard-backup.json'; a.click();
}
function importBackup(e){
  const f=e.target.files[0]; if(!f) return;
  const r=new FileReader();
  r.onload=ev=>{
    try{ Object.assign(S,JSON.parse(ev.target.result)); renderPanel(); renderCanvas(); renderIntelBar(); renderBizLabel(); toast('Imported ✓','ok'); }
    catch(x){toast('Invalid file','er');}
  };
  r.readAsText(f);
}
function clearData(){
  if(!confirm('Clear all data?')) return;
  localStorage.removeItem('sb4');
  S={weekOffset:0,staff:[],templates:[],blocks:[],weekTemplates:[],cfg:S.cfg};
  seedTemplates(); renderPanel(); renderCanvas(); renderIntelBar(); toast('Cleared','ok');
}

