// UI HELPERS
// ══════════════════════════════════════════════════
function buildColorPicker(containerId,selected,key){
  selectedColor[key]=selected||COLORS[0];
  document.getElementById(containerId).innerHTML=COLORS.map(col=>
    `<div class="csw${col===(selected||COLORS[0])?' on':''}" style="background:${col}" data-c="${col}"
      onclick="pickColor('${containerId}','${col}','${key}')"></div>`).join('');
}
function pickColor(containerId,col,key){
  selectedColor[key]=col;
  document.querySelectorAll(`#${containerId} .csw`).forEach(el=>el.classList.toggle('on',el.dataset.c===col));
}
function buildAvRow(containerId,avail){
  document.getElementById(containerId).innerHTML=DAYS.map((d,i)=>{
    const chk=avail?avail[i]!==false:true;
    return`<div class="avbox${chk?' on':''}" id="av-${i}">
      <div class="avd">${d[0]}</div>
      <input type="checkbox" ${chk?'checked':''} onchange="togAv(${i},this.checked)">
    </div>`;
  }).join('');
}
function togAv(i,v){ const el=document.getElementById('av-'+i); if(el) el.classList.toggle('on',v); }
function tagKey(e,wid,iid){
  if(e.key==='Enter'||e.key===','){
    e.preventDefault();
    const v=e.target.value.trim().replace(/,$/,''); if(!v) return;
    if(!tagData[wid]) tagData[wid]=[];
    tagData[wid].push(v); renderTags(wid,iid,tagData[wid]); e.target.value='';
  }
}
function renderTags(wid,iid,tags){
  tagData[wid]=[...tags];
  const wrap=document.getElementById(wid), inp=document.getElementById(iid);
  wrap.querySelectorAll('.tag').forEach(t=>t.remove());
  tags.forEach((t,i)=>{
    const el=document.createElement('span'); el.className='tag';
    el.innerHTML=`${t} <span class="tag-x" onclick="rmTag('${wid}','${iid}',${i})">✕</span>`;
    wrap.insertBefore(el,inp);
  });
}
function rmTag(wid,iid,idx){ if(!tagData[wid]) return; tagData[wid].splice(idx,1); renderTags(wid,iid,tagData[wid]); }
function openM(id){ document.getElementById(id).classList.add('open'); }
function closeM(id){ document.getElementById(id).classList.remove('open'); }
document.querySelectorAll('.moverlay').forEach(m=>m.addEventListener('click',e=>{if(e.target===m)m.classList.remove('open');}));
function toast(msg,type='ok'){
  const a=document.getElementById('toasts');
  const el=document.createElement('div'); el.className=`toast ${type}`; el.textContent=msg;
  a.appendChild(el); setTimeout(()=>el.remove(),2400);
}

// ── TIME HELPERS ──
function parseRowLabel(label){
  if(!label) return ['09:00','17:00'];
  const parts=label.split('–'); if(parts.length<2) return ['09:00','17:00'];
  return [toT24(parts[0].trim()),toT24(parts[1].trim())];
}
function toT24(t){
  if(!t) return '';
  if(/^\d{2}:\d{2}$/.test(t)) return t;
  const m=t.toLowerCase().match(/(\d+):?(\d*)\s*(am|pm)?/); if(!m) return '';
  let h=parseInt(m[1]),min=parseInt(m[2]||'0');
  if(m[3]==='pm'&&h!==12)h+=12;
  if(m[3]==='am'&&h===12)h=0;
  return`${String(h).padStart(2,'0')}:${String(min).padStart(2,'0')}`;
}
function fmt12(t24){
  if(!t24) return '';
  const[h,m]=t24.split(':').map(Number);
  const ap=h>=12?'pm':'am', h12=h%12||12;
  return`${h12}:${String(m).padStart(2,'0')}${ap}`;
}
function hexA(hex,a){
  const r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16);
  return`rgba(${r},${g},${b},${a})`;
}

