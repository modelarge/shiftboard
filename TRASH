// ══════════════════════════════════════════════════
// INTELLIGENCE BAR — hours + availability + overlap detection
// ══════════════════════════════════════════════════
function calcHoursMap(){
  const m={};
  S.blocks.forEach(b=>b.rows.forEach(r=>Object.values(r.cells||{}).forEach(shifts=>shifts.forEach(s=>{
    if(!s.empId) return;
    m[s.empId]=(m[s.empId]||0)+hrsBetween(s.start,s.end);
  }))));
  return m;
}
function hrsBetween(a,b){
  if(!a||!b) return 0;
  const toM=t=>{
    const c=t.toLowerCase().replace(/[ap]m/,'').trim();
    const[h,min]=c.split(':').map(Number);
    let hr=h;
    if(t.toLowerCase().includes('pm')&&h!==12)hr+=12;
    if(t.toLowerCase().includes('am')&&h===12)hr=0;
    return hr*60+(min||0);
  };
  let d=toM(b)-toM(a); if(d<0)d+=1440;
  return Math.round(d/60*10)/10;
}
function toMins(t){
  if(!t) return 0;
  const c=t.toLowerCase().replace(/[ap]m/,'').trim();
  const[h,m]=(c+':0').split(':').map(Number);
  let hr=h;
  if(t.toLowerCase().includes('pm')&&h!==12)hr+=12;
  if(t.toLowerCase().includes('am')&&h===12)hr=0;
  return hr*60+(m||0);
}
function getIssuesPerEmp(){
  // Returns {empId: [issue strings]}
  const issues={};
  const byEmpDay={};
  S.blocks.forEach(b=>b.rows.forEach(r=>{
    Object.entries(r.cells||{}).forEach(([di,shifts])=>{
      shifts.forEach(s=>{
        if(!s.empId) return;
        // Availability
        const emp=S.staff.find(e=>e.id===s.empId);
        if(emp&&emp.avail&&emp.avail[parseInt(di)]===false){
          if(!issues[s.empId]) issues[s.empId]=[];
          issues[s.empId].push(`Not avail ${DAYS[parseInt(di)]}`);
        }
        // Track for overlap
        const key=`${s.empId}_${di}`;
        if(!byEmpDay[key]) byEmpDay[key]=[];
        byEmpDay[key].push({...s,block:b.label});
      });
    });
  }));
  // Overlap detection
  Object.entries(byEmpDay).forEach(([key,shifts])=>{
    if(shifts.length<2) return;
    const [empId,di]=key.split('_');
    for(let i=0;i<shifts.length;i++){
      for(let j=i+1;j<shifts.length;j++){
        const a=shifts[i],bk=shifts[j];
        if(toMins(a.start)<toMins(bk.end)&&toMins(bk.start)<toMins(a.end)){
          if(!issues[empId]) issues[empId]=[];
          issues[empId].push(`Overlap ${DAYS[parseInt(di)]}`);
        }
      }
    }
  });
  // Deduplicate per emp
  Object.keys(issues).forEach(k=>{ issues[k]=[...new Set(issues[k])]; });
  return issues;
}

function renderIntelBar(){
  const scroll=document.getElementById('intel-scroll');
  const hrsMap=calcHoursMap();
  const issuesMap=getIssuesPerEmp();
  const ot=S.cfg.ot||40;

  if(!S.staff.length){
    scroll.innerHTML='<span style="font-size:.73rem;color:var(--text3)">Add employees to track hours & conflicts.</span>';
    renderConflicts(); renderWeekTemplates(); return;
  }
  scroll.innerHTML=S.staff.map(e=>{
    const h=hrsMap[e.id]||0;
    const hDisp=`${Math.floor(h)}h${h%1?` ${Math.round(h%1*60)}m`:''}`;
    const isOt=h>ot;
    const myIssues=issuesMap[e.id]||[];
    const laborCost=e.payRate?`$${(h*e.payRate).toFixed(2)}`:'';
    let cls='intel-pill';
    if(isOt) cls+=' ot';
    if(myIssues.length) cls+=' warn';
    return`<div class="${cls}" title="${isOt?`Overtime threshold: ${ot}h`:''}${myIssues.length?' | '+myIssues.join(', '):''}">
      <div class="ip-top">
        <span class="ip-dot" style="background:${e.color}"></span>
        <span class="ip-name">${e.fname} ${e.lname[0]}.</span>
        <span class="ip-hrs${isOt?' ot-hrs':''}">${hDisp}${isOt?' 🔴':''}</span>
      </div>
      ${laborCost?`<div style="font-size:.62rem;color:#7ec8a0;font-weight:600">${laborCost} labor</div>`:''}
      ${myIssues.length?`<div class="ip-issues">⚠ ${myIssues.join(' · ')}</div>`:''}
    </div>`;
  }).join('');
  renderConflicts(); renderWeekTemplates();
}

function renderConflicts(){
  const banner=document.getElementById('conflict-banner'); if(!banner) return;
  const issuesMap=getIssuesPerEmp();
  const msgs=[];
  Object.entries(issuesMap).forEach(([eid,issues])=>{
    const emp=S.staff.find(e=>e.id===eid); if(!emp) return;
    issues.forEach(i=>msgs.push(`<strong>${emp.fname} ${emp.lname}</strong> — ${i}`));
  });
  if(msgs.length){ banner.className='has-conflicts'; banner.innerHTML=msgs.map(m=>`<div class="cf-row">${m}</div>`).join(''); }
  else { banner.className=''; banner.innerHTML=''; }
}

